{
  "tests": [
    {
      "name": "POST contact form",
      "method": "POST",
      "path": "/",
      "body": {"name": "Тест Родитель", "phone": "+7 900 000 00 00", "email": "test@test.ru", "message": "Тестовое сообщение"},
      "expectedStatus": 200,
      "expectedBody": {"success": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "POST missing fields",
      "method": "POST",
      "path": "/",
      "body": {"name": ""},
      "expectedStatus": 400,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "Укажите имя и сообщение"}
    }
  ]
}